---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// 接收 Markdown 最上方傳過來的設定資料
const { frontmatter } = Astro.props;
---

<Layout>
  <Navbar />
  
  <main class="pt-24 pb-32 bg-white min-h-screen">
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="mb-12 text-center border-b border-slate-100 pb-12">
        <div class="inline-flex items-center gap-2 text-sm text-sky-600 font-bold bg-sky-50 px-4 py-1.5 rounded-full mb-6">
          {frontmatter.category || '衛教專欄'}
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-slate-800 mb-6 leading-tight">
          {frontmatter.title}
        </h1>
        <div class="text-slate-500 font-medium">
          發布日期：{frontmatter.date}
        </div>
      </div>

      <!-- 這裡負責把 Markdown 轉成網頁格式顯示出來 -->
      <div class="markdown-content">
        <slot />
      </div>
      
    </article>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* 簡單幫 Markdown 的內容加上基本排版，讓文字好讀一點 */
  .markdown-content h2 { font-size: 1.875rem; font-weight: 800; margin-top: 2rem; margin-bottom: 1rem; color: #1e293b; }
  .markdown-content p { margin-bottom: 1.5rem; line-height: 1.8; color: #475569; font-size: 1.125rem; }
  .markdown-content ol { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 1.5rem; color: #475569; font-size: 1.125rem; }
  .markdown-content li { margin-bottom: 0.5rem; }
</style>