---
import { getCollection } from 'astro:content';
// BlogPost.astro 位於 layouts 資料夾，與 Layout.astro 是鄰居
import Layout from './Layout.astro';
// 找 components 需要往上一層再進入
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// 接收來自 .md 檔案的資料
const { title, date, pubDate, category, tags, series, description } = Astro.props.frontmatter || Astro.props;

// 抓取所有文章用來處理系列與推薦功能
const allPosts = await getCollection('blog');

// 系列專題邏輯
const seriesPosts = series 
  ? allPosts.filter(p => (p.data as any).series === series).sort((a, b) => {
      const d1 = new Date((a.data as any).date || a.data.pubDate || 0).getTime();
      const d2 = new Date((b.data as any).date || b.data.pubDate || 0).getTime();
      return d1 - d2; // 系列文章通常由舊到新排
    })
  : [];

// 島主推薦邏輯 (在 md 檔標註 recommend: true)
const recommendedPosts = allPosts
  .filter(p => (p.data as any).recommend === true && p.data.title !== title)
  .slice(0, 2);

// 處理日期格式
const displayDate = date || pubDate;
---

<Layout title={title}>
  <Navbar />

  <main class="pt-24 pb-32 bg-white min-h-screen">
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <header class="text-center mb-12">
        {/* 分類泡泡 */}
        <div class="inline-block bg-sky-50 text-sky-600 px-4 py-1.5 rounded-full font-bold text-sm mb-6">
          {category || '衛教資訊'}
        </div>

        {/* 支援換行的標題 */}
        <h1 
          class="text-4xl md:text-5xl font-black text-slate-800 mb-8 leading-tight tracking-tight"
          set:html={title}
        />

        <div class="flex flex-col items-center gap-4">
          {displayDate && (
            <div class="text-slate-400 font-medium italic">
              發布日期：{new Date(displayDate).toLocaleDateString('zh-TW')}
            </div>
          )}
          
          {/* 標籤區塊 */}
          {tags && (
            <div class="flex flex-wrap justify-center gap-2 mt-2">
              {tags.map((tag: string) => (
                <span class="text-xs font-bold text-sky-400 bg-sky-50/50 px-3 py-1 rounded-lg">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </header>

      {/* 系列專題導覽盒 */}
      {series && seriesPosts.length > 1 && (
        <div class="mb-12 p-6 bg-slate-50 rounded-3xl border border-slate-100 shadow-sm">
          <div class="flex items-center gap-2 text-sky-600 font-bold mb-4">
            <i data-lucide="layers" class="w-5 h-5"></i>
            <span>{series} 專題系列文章</span>
          </div>
          <ul class="space-y-3">
            {seriesPosts.map((p) => (
              <li>
                <a href={`/blog/${p.id}/`} class={`block text-sm transition-colors ${p.data.title === title ? 'text-sky-500 font-bold' : 'text-slate-500 hover:text-sky-400'}`}>
                  {p.data.title === title && <span class="mr-2">▸</span>}
                  {p.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* 文章正文內容 */}
      <div class="prose prose-lg prose-slate max-w-none 
        prose-headings:font-black prose-headings:text-slate-800
        prose-p:text-slate-600 prose-p:leading-relaxed
        prose-strong:text-sky-600 prose-strong:font-bold
        prose-img:rounded-3xl prose-img:shadow-lg
        prose-blockquote:border-sky-200 prose-blockquote:bg-sky-50/50 prose-blockquote:py-2 prose-blockquote:rounded-r-2xl
        selection:bg-sky-100 article-content">
        <slot />
      </div>

      <footer class="mt-20 pt-10 border-t border-slate-100">
        {/* 島主推薦區塊 */}
        {recommendedPosts.length > 0 && (
          <div class="mb-16">
            <h3 class="text-xl font-bold text-slate-800 mb-8 flex items-center gap-2">
              <i data-lucide="star" class="text-amber-400 w-5 h-5"></i>
              島主推薦必讀
            </h3>
            <div class="grid sm:grid-cols-2 gap-6">
              {recommendedPosts.map((p) => (
                <a href={`/blog/${p.id}/`} class="group block p-6 bg-slate-50 rounded-2xl border border-slate-100 hover:border-sky-200 hover:shadow-md transition-all">
                  <span class="text-xs font-bold text-sky-400 block mb-2">{(p.data as any).category || '衛教資訊'}</span>
                  <h4 class="font-bold text-slate-700 group-hover:text-sky-600 transition-colors line-clamp-1">{p.data.title}</h4>
                </a>
              ))}
            </div>
          </div>
        )}

        <a href="/blog" class="inline-flex items-center gap-2 text-sky-600 font-bold hover:gap-3 transition-all">
          <i data-lucide="arrow-left" class="w-5 h-5"></i> 
          回到衛教專欄
        </a>
      </footer>

    </article>
  </main>

  <Footer />
</Layout>

<style is:global>
  body {
    font-family: 'Noto Sans TC', sans-serif;
  }
  
  /* 段落開頭自動空兩格 */
  .article-content p {
    text-indent: 2em;
    margin-bottom: 1.5rem;
  }

  /* 標題層級樣式微調 */
  .prose h1 { 
    font-size: 2.5rem !important; 
    margin-top: 2.5rem !important;
    margin-bottom: 1.5rem !important;
    color: #1e293b !important;
  }
  .prose h2 { 
    font-size: 2rem !important; 
    margin-top: 2rem !important;
    margin-bottom: 1rem !important;
    border-bottom: 2px solid #f1f5f9;
    padding-bottom: 0.5rem;
    color: #1e293b !important;
  }
  .prose h3 { 
    font-size: 1.5rem !important; 
    margin-top: 1.5rem !important;
    margin-bottom: 0.75rem !important;
    color: #0369a1 !important;
  }

  /* 列表不縮進 */
  .article-content li {
    text-indent: 0;
  }
</style>