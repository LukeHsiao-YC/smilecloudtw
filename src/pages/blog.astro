---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// 這裡的路徑 ./posts/*.md 代表「找我旁邊那個叫 posts 資料夾裡的 md 檔」
const posts = Object.values(import.meta.glob('./posts/*.md', { eager: true }));

// 按照日期排序（新的在上面）
const sortedPosts = posts.sort((a: any, b: any) => {
  const dateA = a.frontmatter?.date ? new Date(a.frontmatter.date).getTime() : 0;
  const dateB = b.frontmatter?.date ? new Date(b.frontmatter.date).getTime() : 0;
  return dateB - dateA;
});

// 如果你想確認有沒有抓到，可以在瀏覽器按 F12 看 Console
console.log("文章清單：", sortedPosts);
---

<Layout>
  <Navbar />

  <main class="pt-24 pb-32 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-black text-slate-800 mb-4 text-center">衛教專欄</h1>
        <div class="w-20 h-2 bg-gradient-to-r from-sky-300 to-sky-500 mx-auto rounded-full"></div>
        <p class="mt-6 text-lg text-slate-600">與你分享兒童腸胃健康、體重管理與實用育兒知識</p>
      </div>

      <div class="grid gap-8">
        {sortedPosts.length === 0 ? (
          <div class="text-center py-20 bg-white rounded-3xl border-2 border-dashed border-slate-200 text-slate-400">
            <p class="text-xl font-bold">目前還沒有文章喔</p>
            <p class="mt-2 text-sm">快去 src/pages/posts/ 資料夾新增第一篇 .md 檔案吧！</p>
          </div>
        ) : (
          sortedPosts.map((post: any) => (
            <a href={post.url} class="block group">
              <article class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100 hover:shadow-xl hover:shadow-sky-100 hover:-translate-y-1 transition-all duration-300">
                <div class="flex items-center gap-4 text-sm text-slate-400 mb-4">
                  <span class="bg-sky-50 text-sky-600 px-4 py-1.5 rounded-full font-bold">
                    {post.frontmatter.category || '衛教資訊'}
                  </span>
                  <span class="font-medium">{post.frontmatter.date}</span>
                </div>
                <h2 class="text-2xl md:text-3xl font-black text-slate-800 mb-4 group-hover:text-sky-600 transition-colors">
                  {post.frontmatter.title}
                </h2>
                <p class="text-slate-500 leading-relaxed mb-6 line-clamp-2">
                  {post.frontmatter.description}
                </p>
                <div class="text-sky-600 font-bold flex items-center gap-2 group-hover:gap-3 transition-all">
                  繼續閱讀 <i data-lucide="arrow-right" class="w-5 h-5"></i>
                </div>
              </article>
            </a>
          ))
        )}
      </div>
    </div>
  </main>

  <Footer />
</Layout>