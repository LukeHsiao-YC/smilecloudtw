---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

// 1. 抓取所有文章
const posts = await getCollection('blog');

// 2. 按照日期排序
// 加入防呆機制：如果 pubDate 是空的，就當作 0 (代表時間最早)，這樣 TypeScript 就不會報錯了
const sortedPosts = posts.sort((a, b) => {
  const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
  const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
  return dateB - dateA;
});

// 3. 自動找出所有的專題系列
// 因為你的 schema 還沒定義 series，我們用 (data as any) 繞過檢查
const allSeries = [...new Set(posts.map(p => (p.data as any).series).filter(Boolean))];

// 針對每個系列計算文章數，並保留該系列的所有文章以便展開
const seriesData = allSeries.map(seriesName => {
  const postsInSeries = posts.filter(p => (p.data as any).series === seriesName);
  return {
    name: seriesName,
    count: postsInSeries.length,
    allPosts: postsInSeries
  };
});
---

<Layout title="衛教專欄 | Smilecloud">
  <Navbar />

  <main class="pt-24 pb-32 bg-slate-50 min-h-screen">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-black text-slate-800 mb-4 text-center italic">衛教專欄</h1>
        <div class="w-20 h-2 bg-gradient-to-r from-sky-300 to-sky-500 mx-auto rounded-full"></div>
        <p class="mt-6 text-lg text-slate-600 font-medium">與你分享兒童腸胃健康、體重管理與實用育兒知識</p>
      </div>

      {/* 專題系列展示區 */}
      {seriesData.length > 0 && (
        <div class="mb-20">
          <h2 class="text-xl font-bold text-slate-800 mb-8 flex items-center gap-2">
            <i data-lucide="layers" class="w-5 h-5 text-sky-500"></i>
            精選專題系列
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {seriesData.map((item) => (
              <div class="bg-white p-8 rounded-[2rem] border border-sky-100 shadow-sm hover:shadow-xl hover:border-sky-300 transition-all duration-300 group relative overflow-hidden">
                <div class="absolute top-0 right-0 w-24 h-24 bg-sky-50 rounded-full -mr-8 -mt-8 transition-transform group-hover:scale-150 duration-500 opacity-50"></div>
                
                <div class="relative z-10">
                  <div class="text-sky-600 font-black text-xl mb-2">#{item.name}</div>
                  <div class="text-slate-400 text-sm mb-6 flex items-center gap-2 font-medium">
                    <i data-lucide="book-copy" class="w-4 h-4"></i>
                    目前收錄 {item.count} 篇文章
                  </div>
                  
                  <div class="space-y-3 mb-6">
                    {/* 永遠顯示的前兩篇文章 */}
                    {item.allPosts.slice(0, 2).map(p => (
                      <a href={`/blog/${p.id}/`} class="text-sm text-slate-500 flex items-start gap-2 hover:text-sky-600 transition-colors group/link">
                        <span class="text-sky-300 font-bold mt-0.5 group-hover/link:text-sky-500 transition-colors">·</span>
                        <span class="line-clamp-1 italic">{p.data.title}</span>
                      </a>
                    ))}

                    {/* 超過兩篇才顯示展開按鈕與隱藏文章 */}
                    {item.count > 2 && (
                      <details class="group/details cursor-pointer pt-1">
                        <summary class="text-sky-500 text-sm font-bold flex items-center gap-1 opacity-80 hover:opacity-100 transition-opacity focus:outline-none list-none [&::-webkit-details-marker]:hidden">
                          <span class="group-open/details:hidden">展開其餘 {item.count - 2} 篇文章</span>
                          <span class="hidden group-open/details:inline">收合文章</span>
                          <i data-lucide="chevron-down" class="w-4 h-4 group-open/details:rotate-180 transition-transform duration-300"></i>
                        </summary>
                        <div class="space-y-3 pt-4 pb-2">
                          {item.allPosts.slice(2).map(p => (
                            <a href={`/blog/${p.id}/`} class="text-sm text-slate-500 flex items-start gap-2 hover:text-sky-600 transition-colors group/link">
                              <span class="text-sky-300 font-bold mt-0.5 group-hover/link:text-sky-500 transition-colors">·</span>
                              <span class="line-clamp-1 italic">{p.data.title}</span>
                            </a>
                          ))}
                        </div>
                      </details>
                    )}
                  </div>
                  
                  {item.count <= 2 && (
                    <div class="text-sky-500 text-sm font-bold flex items-center gap-1 opacity-60">
                      點擊上方文章開始閱讀
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <h2 class="text-xl font-bold text-slate-800 mb-8 flex items-center gap-2">
        <i data-lucide="list" class="w-5 h-5 text-sky-500"></i>
        最新發布內容
      </h2>
      
      <div class="grid gap-8">
        {sortedPosts.length === 0 ? (
          <div class="text-center py-20 bg-white rounded-3xl border-2 border-dashed border-slate-200 text-slate-400">
            <i data-lucide="inbox" class="w-12 h-12 mx-auto mb-4 opacity-20"></i>
            <p class="text-xl font-bold">目前還沒有文章喔</p>
          </div>
        ) : (
          sortedPosts.map((post) => (
            <a href={`/blog/${post.id}/`} class="block group">
              <article class="bg-white rounded-[2rem] p-8 shadow-sm border border-slate-100 group-hover:shadow-xl group-hover:shadow-sky-100 group-hover:-translate-y-1 transition-all duration-300 relative overflow-hidden">
                
                {(post.data as any).series && (
                  <div class="absolute top-0 right-0 bg-sky-100 text-sky-600 px-6 py-2 rounded-bl-3xl text-xs font-black tracking-wider">
                    {(post.data as any).series} 系列
                  </div>
                )}
                
                <div class="flex items-center gap-4 text-sm text-slate-400 mb-6">
                  <span class="bg-sky-50 text-sky-600 px-4 py-1.5 rounded-full font-bold">
                    {(post.data as any).category || '衛教資訊'}
                  </span>
                  <span class="font-medium italic tracking-tighter">
                    {/* 這裡也加上防呆，如果沒日期就不顯示 */}
                    {post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' }) : '未定日期'}
                  </span>
                </div>
                
                <h2 
                  class="text-2xl md:text-3xl font-black text-slate-800 mb-4 group-hover:text-sky-600 transition-colors leading-tight"
                  set:html={post.data.title}
                />

                <p class="text-slate-500 leading-relaxed mb-8 line-clamp-2">
                  {post.data.description}
                </p>
                
                <div class="text-sky-600 font-bold flex items-center gap-2 group-hover:gap-4 transition-all">
                  點擊展開閱讀 <i data-lucide="arrow-right" class="w-5 h-5 transition-transform group-hover:translate-x-1"></i>
                </div>
              </article>
            </a>
          ))
        )}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap');
  
  body {
    font-family: 'Noto Sans TC', sans-serif;
  }
</style>