---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

// 自動找出所有的專題系列 (排除重複且不為空的)
const allSeries = [...new Set(allPosts.map(p => (p.data as any).series).filter(Boolean))];

// 針對每個系列計算文章數，這次把限制數量的 .slice(0, 3) 拿掉，讓全部系列都能顯示
const seriesData = allSeries.map(seriesName => {
  const count = allPosts.filter(p => (p.data as any).series === seriesName).length;
  return { name: seriesName, count };
});
---

<!DOCTYPE html>
<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smilecloud 微笑雲朵 | 蕭宇超醫師</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
  
