        </div>
      </div>
    </section>

    <!-- 知識加油站預覽區塊 (改為顯示所有系列) -->
    <section id="blog" class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-4">知識加油站</h2>
          <div class="w-20 h-1.5 bg-sky-400 mx-auto rounded-full"></div>
          <p class="mt-4 text-lg text-slate-600">精選衛教專題，輕鬆看懂兒童營養與成長密碼。</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-12">
          {seriesData.length > 0 ? (
            seriesData.map((item) => (
              <a href="/blog" class="bg-slate-50 p-8 rounded-3xl shadow-sm border border-slate-100 hover:shadow-xl hover:border-sky-200 transition-all group flex flex-col items-center text-center h-full">
                <div class="bg-sky-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                  <i data-lucide="layers" class="text-sky-500 w-8 h-8"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-800 mb-3 group-hover:text-sky-600 transition-colors">
                  #{item.name}
                </h3>
                <p class="text-slate-500 font-medium mt-auto">
                  共收錄 {item.count} 篇文章
                </p>
              </a>
            ))
          ) : (
            <div class="col-span-3 text-center py-10 text-slate-500">
              目前還沒有專題喔，敬請期待島主的新分享！
            </div>
          )}
        </div>

        <div class="flex justify-center">
          <a href="/blog" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-sky-50 text-sky-600 border-2 border-sky-100 px-8 py-4 rounded-full font-bold text-lg transition-all shadow-sm hover:shadow-md">
            <i data-lucide="book-open" class="w-5 h-5"></i>
