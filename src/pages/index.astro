---
// 保持乾淨的設定區塊
---

<!DOCTYPE html>
<html lang="zh-TW" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smilecloud 微笑雲朵 | 蕭宇超醫師</title>
  
  <!-- 加上 is:inline 護身符，讓 Astro 系統絕對不要干擾排版魔法 -->
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <script is:inline src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 font-sans selection:bg-sky-200">
  
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-sky-100">
