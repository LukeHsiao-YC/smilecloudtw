---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />

  <main>
    <!-- 主視覺區：介紹島嶼與核心觀念 -->
    <section class="relative pt-24 pb-32 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-sky-100 via-white to-slate-50 z-0"></div>
      
      <!-- 裝飾用 SVG 雲朵 -->
      <div class="absolute top-20 left-10 md:left-20 text-sky-200/60 animate-bounce transition-all duration-[3000ms]">
        <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19c2.5 0 4.5-2 4.5-4.5 0-2-1.5-3.5-3.5-4-1-2.5-3.5-4-6.5-4-3 0-5.5 1.5-6.5 4-2 .5-3.5 2-3.5 4 0 2.5 2 4.5 4.5 4.5z"/></svg>
      </div>
      
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white border border-sky-100 shadow-sm text-sky-600 font-bold mb-8 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fb7185" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          <span>蕭宇超醫師的健康冒險島</span>
        </div>
        
        <h1 class="text-5xl md:text-7xl font-black text-slate-800 mb-8 leading-tight tracking-tight">
          告別雲朵身材<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-blue-600">一起健康生活</span>
        </h1>
        
        <p class="text-lg md:text-xl text-slate-600 mb-12 max-w-2xl mx-auto leading-relaxed">
          我是健康冒險島的島主蕭宇超醫師，歡迎登島。在這裡我們不只談論體重，更要陪孩子一起愛上運動，把健康變成一場冒險。
        </p>

        <div class="flex justify-center mt-12">
          <a href="#features" class="inline-flex items-center justify-center gap-3 bg-amber-400 hover:bg-amber-500 text-slate-900 px-10 py-4 rounded-full font-black text-xl transition-all shadow-lg shadow-amber-200 hover:shadow-xl transform hover:-translate-y-1">
            開始探索互動區
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16 10-4 4-4-4"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- 探索互動區：保留在首頁作為核心功能 -->
    <section id="features" class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-left">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-black text-slate-800 mb-4">探索互動區</h2>
          <div class="w-24 h-2 bg-gradient-to-r from-sky-300 to-sky-500 mx-auto rounded-full"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-slate-50 rounded-3xl p-8 border border-slate-100 hover:bg-white hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 flex flex-col h-full text-left">
            <div class="bg-sky-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-6 text-sky-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="text-2xl font-black text-slate-800 mb-4">健康冒險島</h3>
            <p class="text-slate-600 mb-8 flex-grow leading-relaxed">
              透過闖關遊戲，陪孩子認識自己的身體，學習健康飲食與放鬆心情的小秘訣。
            </p>
            <a href="https://smilecloud.tw/for_healthy_children/" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center w-full bg-sky-100 text-sky-700 font-bold py-3 rounded-xl hover:bg-sky-50 transition-colors">
              立即登島挑戰
            </a>
          </div>

          <div class="bg-slate-50 rounded-3xl p-8 border border-slate-100 hover:bg-white hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 flex flex-col h-full text-left">
            <div class="bg-indigo-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-6 text-indigo-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>
            </div>
            <h3 class="text-2xl font-black text-slate-800 mb-4">身材檢測站</h3>
            <p class="text-slate-600 mb-8 flex-grow leading-relaxed">
              透過簡單的指標評估，快速了解目前的身體指標。掌握健康現狀，從這裡開始。
            </p>
            <a href="https://smilecloud.tw/obesity-survey-app/" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center w-full bg-indigo-50 text-indigo-700 font-bold py-3 rounded-xl hover:bg-indigo-100 transition-colors">
              開始評估檢測
            </a>
          </div>

          <div class="bg-slate-50 rounded-3xl p-8 border border-slate-100 hover:bg-white hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 flex flex-col h-full text-left">
            <div class="bg-amber-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-6 text-amber-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a3 3 0 0 0-3-3H5a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V8Z"/><path d="M10 12h.01"/><path d="M14 12h.01"/><path d="M6 12h.01"/></svg>
            </div>
            <h3 class="text-2xl font-black text-slate-800 mb-4">專屬運動處方</h3>
            <p class="text-slate-600 mb-8 flex-grow leading-relaxed">
              不知道該怎麼帶孩子運動嗎。輸入基本資料，我們會為你量身打造階段性的運動計畫。
            </p>
            <a href="https://smilecloud.tw/gogoexercise/" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center w-full bg-amber-50 text-amber-700 font-bold py-3 rounded-xl hover:bg-amber-100 transition-colors">
              領取專屬處方
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>

<style>
  /* 簡單的漂浮動畫，讓雲朵看起來更有趣 */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>